{
  "name": "aiqt",
  "version": "0.1.0",
  "description": "AI code quality toolkit — deterministic linter for the AI coding era",
  "type": "module",
  "bin": {
    "aiqt": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outdir dist --target node",
    "build:action": "npx ncc build src/action/main.ts -o dist/action --source-map --license licenses.txt",
    "test": "bun test",
    "lint": "bunx biome check",
    "typecheck": "bunx tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "linter",
    "ai",
    "code-quality",
    "ast",
    "static-analysis"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhvbhushan/aiqt"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@ast-grep/lang-python": "^0.0.6",
    "@ast-grep/napi": "^0.42.0",
    "commander": "^13.1.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/sarif": "^2.1.7",
    "@vercel/ncc": "^0.38.4",
    "bun-types": "^1.3.11",
    "typescript": "^5.8.3"
  },
  "contributes": {
    "problemMatchers": [
      {
        "name": "aiqt",
        "owner": "aiqt",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+):\\s+(error|warning|info)\\s+(.+)\\s+\\[(.+)\\]$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5,
          "code": 6
        }
      }
    ]
  }
}
